# Cloudflare Workers AI credentials (for image-to-prompt generation)
# Get these from https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
CLOUDFLARE_API_TOKEN=your_api_token_here

# SMTP credentials (for the contact form)
# Use the SMTP details of the mailbox you SEND from. Examples:
#
#   Gmail / Google Workspace (use an App Password, NOT your login password):
#     SMTP_HOST=smtp.gmail.com
#     SMTP_PORT=587
#     SMTP_USER=you@gmail.com
#     SMTP_PASS=xxxx xxxx xxxx xxxx
#
#   Zoho Mail:
#     SMTP_HOST=smtp.zoho.com
#     SMTP_PORT=465
#     SMTP_USER=you@enprico.ca
#     SMTP_PASS=your_zoho_app_password
#
#   Outlook / Microsoft 365:
#     SMTP_HOST=smtp.office365.com
#     SMTP_PORT=587
#     SMTP_USER=you@enprico.ca
#     SMTP_PASS=your_password_or_app_password
#
#   Namecheap PrivateEmail:
#     SMTP_HOST=mail.privateemail.com
#     SMTP_PORT=587
#     SMTP_USER=you@enprico.ca
#     SMTP_PASS=your_mailbox_password
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Optional. Address that appears in the "From" line. If unset, SMTP_USER is used.
# Some providers require this to match SMTP_USER or a verified alias.
CONTACT_FROM_EMAIL=Prompto <noreply@enprico.ca>
