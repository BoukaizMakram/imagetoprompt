# ─── AI model credentials ─────────────────────────────────────────────────
# OpenAI — used for Standard (gpt-4o-mini) and Enhanced (gpt-4.1-mini) tiers
OPENAI_API_KEY=sk-...

# Anthropic — used for Premium (claude-haiku-4-5) tier
ANTHROPIC_API_KEY=sk-ant-...

# SMTP credentials (for the contact form)
# Use the SMTP details of the mailbox you SEND from. Examples:
#
#   Gmail / Google Workspace (use an App Password, NOT your login password):
#     SMTP_HOST=smtp.gmail.com
#     SMTP_PORT=587
#     SMTP_USER=you@gmail.com
#     SMTP_PASS=xxxx xxxx xxxx xxxx
#
#   Zoho Mail:
#     SMTP_HOST=smtp.zoho.com
#     SMTP_PORT=465
#     SMTP_USER=you@enprico.ca
#     SMTP_PASS=your_zoho_app_password
#
#   Outlook / Microsoft 365:
#     SMTP_HOST=smtp.office365.com
#     SMTP_PORT=587
#     SMTP_USER=you@enprico.ca
#     SMTP_PASS=your_password_or_app_password
#
#   Namecheap PrivateEmail:
#     SMTP_HOST=mail.privateemail.com
#     SMTP_PORT=587
#     SMTP_USER=you@enprico.ca
#     SMTP_PASS=your_mailbox_password
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Optional. Address that appears in the "From" line. If unset, SMTP_USER is used.
# Some providers require this to match SMTP_USER or a verified alias.
CONTACT_FROM_EMAIL=imageprompting.org <noreply@enprico.ca>

# ─── Supabase ─────────────────────────────────────────────────────────────
# Create a project at https://supabase.com → Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key
# Service-role key — keep SECRET. Required for credit consumption + webhooks.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ─── Stripe ───────────────────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
# After creating an endpoint at /api/stripe/webhook in the Stripe dashboard:
STRIPE_WEBHOOK_SECRET=whsec_...

# One-time Price IDs (NOT subscriptions). Create three prices in Stripe:
#   Starter   — $9.99 USD one-time     → STRIPE_PRICE_STARTER
#   Pro       — $18.99 USD one-time    → STRIPE_PRICE_PRO
#   Unlimited — $100 USD one-time      → STRIPE_PRICE_UNLIMITED
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_UNLIMITED=price_...

# Public site URL — used to build Stripe success/cancel URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
